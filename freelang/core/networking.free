// ──────────────────────────────────────────────────────────────────────────
// 4. HTTP 요청/응답 처리
// ──────────────────────────────────────────────────────────────────────────

type HTTPRequest = {
  method: string,
  path: string,
  version: string,
  headers: map[string]string,
  body: string
}

type HTTPResponse = {
  status: i32,
  statusText: string,
  headers: map[string]string,
  body: string
}

func parseHTTPRequest(rawData: string) -> (bool, HTTPRequest) {
  // Raw HTTP 요청을 파싱
  // Format: METHOD PATH HTTP/1.1\r\nHeader: Value\r\n\r\nBody

  let lines = rawData.split("\r\n")

  if lines.length() == 0 {
    return (false, {
      method: "",
      path: "",
      version: "",
      headers: {},
      body: ""
    })
  }

  // 요청 라인 파싱: GET /path HTTP/1.1
  let requestLine = lines[0].split(" ")

  if requestLine.length() < 3 {
    return (false, {
      method: "",
      path: "",
      version: "",
      headers: {},
      body: ""
    })
  }

  let method = requestLine[0]
  let path = requestLine[1]
  let version = requestLine[2]

  // 헤더 파싱
  let headers: map[string]string = {}
  let i = 1

  while i < lines.length() {
    let line = lines[i]

    // 빈 줄 = 헤더 끝
    if line.isEmpty() || line == "" {
      break
    }

    // 헤더 파싱: Key: Value
    let colonIdx = line.indexOf(":")
    if colonIdx > 0 {
      let key = line.substring(0, colonIdx).trim()
      let value = line.substring(colonIdx + 1).trim()
      headers[key] = value
    }

    i = i + 1
  }

  // Body 파싱 (빈 줄 이후)
  let body = ""
  if i < lines.length() - 1 {
    body = lines[i + 1]
  }

  return (true, {
    method: method,
    path: path,
    version: version,
    headers: headers,
    body: body
  })
}

func buildHTTPResponse(status: i32, statusText: string, headers: map[string]string, body: string) -> string {
  // HTTP 응답 생성
  // Format: HTTP/1.1 200 OK\r\nHeader: Value\r\n\r\nBody

  let response = "HTTP/1.1 " + i32ToString(status) + " " + statusText + "\r\n"

  // 헤더 추가
  for key in headers {
    let value = headers[key]
    response = response + key + ": " + value + "\r\n"
  }

  // Content-Length 자동 추가
  response = response + "Content-Length: " + i32ToString(body.length()) + "\r\n"

  // 헤더/바디 분리
  response = response + "\r\n"
  response = response + body

  return response
}

// ──────────────────────────────────────────────────────────────────────────
// 5. 멀티플렉싱 (다중 클라이언트 처리)
// ──────────────────────────────────────────────────────────────────────────

type ConnectionPool = {
  connections: [ClientConnection],
  maxConnections: i32
}

func createConnectionPool(maxConnections: i32) -> ConnectionPool {
  return {
    connections: [],
    maxConnections: maxConnections
  }
}

func addConnection(pool: ConnectionPool, conn: ClientConnection) -> bool {
  if pool.connections.length() >= pool.maxConnections {
    println("⚠️  커넥션 풀 가득 찬 상태")
    return false
  }

  pool.connections.push(conn)
  return true
}

func removeConnection(pool: ConnectionPool, fd: i32) -> bool {
  // fd와 일치하는 연결 제거
  let newConnections: [ClientConnection] = []

  for conn in pool.connections {
    if conn.fd != fd {
      newConnections.push(conn)
    }
  }

  pool.connections = newConnections
  return true
}

func getActiveConnectionCount(pool: ConnectionPool) -> i32 {
  return pool.connections.length()
}

// ──────────────────────────────────────────────────────────────────────────
// 6. 타임아웃 및 재시도
// ──────────────────────────────────────────────────────────────────────────

type NetworkConfig = {
  readTimeoutMs: i32,      // 읽기 타임아웃 (밀리초)
  writeTimeoutMs: i32,     // 쓰기 타임아웃 (밀리초)
  maxRetries: i32,         // 최대 재시도 횟수
  keepAliveEnabled: bool   // Keep-Alive 활성화
}

func createNetworkConfig() -> NetworkConfig {
  return {
    readTimeoutMs: 5000,    // 5초
    writeTimeoutMs: 5000,   // 5초
    maxRetries: 3,
    keepAliveEnabled: true
  }
}

func setReadTimeout(fd: i32, timeoutMs: i32) -> bool {
  // net.setsockopt(fd, SO_RCVTIMEO, timeoutMs)
  return true
}

func setWriteTimeout(fd: i32, timeoutMs: i32) -> bool {
  // net.setsockopt(fd, SO_SNDTIMEO, timeoutMs)
  return true
}

func retryOperation(operation: string, maxRetries: i32) -> (bool, string) {
  // 네트워크 작업 재시도 로직

  let retry = 0

  while retry < maxRetries {
    // 작업 실행
    // 성공 시 반환

    retry = retry + 1
  }

  return (false, "Max retries exceeded")
}

// ──────────────────────────────────────────────────────────────────────────
// 7. 에러 처리 및 로깅
// ──────────────────────────────────────────────────────────────────────────

type NetworkError = {
  code: i32,
  message: string,
  operation: string,
  timestamp: i32
}

func createNetworkError(code: i32, message: string, operation: string) -> NetworkError {
  return {
    code: code,
    message: message,
    operation: operation,
    timestamp: getCurrentTimestamp()
  }
}

func handleNetworkError(err: NetworkError) -> string {
  let logMsg = "❌ 네트워크 오류 [" + i32ToString(err.code) + "]: "
  logMsg = logMsg + err.message + " (작업: " + err.operation + ")"

  println(logMsg)

  return logMsg
}

// ──────────────────────────────────────────────────────────────────────────
// 8. 통계 및 모니터링
// ──────────────────────────────────────────────────────────────────────────

type NetworkStats = {
  totalConnections: i32,
  activeConnections: i32,
  bytesRead: i32,
  bytesWritten: i32,
  requestsProcessed: i32,
  errorsEncountered: i32,
  uptime: i32
}

func createNetworkStats() -> NetworkStats {
  return {
    totalConnections: 0,
    activeConnections: 0,
    bytesRead: 0,
    bytesWritten: 0,
    requestsProcessed: 0,
    errorsEncountered: 0,
    uptime: 0
  }
}

func recordConnection(stats: NetworkStats) -> void {
  stats.totalConnections = stats.totalConnections + 1
  stats.activeConnections = stats.activeConnections + 1
}

func recordDisconnection(stats: NetworkStats) -> void {
  stats.activeConnections = stats.activeConnections - 1
}

func recordBytesRead(stats: NetworkStats, bytes: i32) -> void {
  stats.bytesRead = stats.bytesRead + bytes
}

func recordBytesWritten(stats: NetworkStats, bytes: i32) -> void {
  stats.bytesWritten = stats.bytesWritten + bytes
}

func printNetworkStats(stats: NetworkStats) -> void {
  println("")
  println("📊 네트워크 통계:")
  println("  총 연결: " + i32ToString(stats.totalConnections))
  println("  활성 연결: " + i32ToString(stats.activeConnections))
  println("  읽은 바이트: " + i32ToString(stats.bytesRead))
  println("  쓴 바이트: " + i32ToString(stats.bytesWritten))
  println("  처리한 요청: " + i32ToString(stats.requestsProcessed))
  println("  오류: " + i32ToString(stats.errorsEncountered))
  println("")
}

// ──────────────────────────────────────────────────────────────────────────
// 9. 유틸리티 함수
// ──────────────────────────────────────────────────────────────────────────

func getCurrentTimestamp() -> i32 {
  // 현재 Unix 타임스탐프 반환
  return 0
}

func i32ToString(n: i32) -> string {
  if n == 0 {
    return "0"
  }

  let negative = n < 0
  let abs = if negative { -n } else { n }

  let result = ""
  let temp = abs
  while temp > 0 {
    let digit = temp % 10
    let char = if digit == 0 { "0" }
             else if digit == 1 { "1" }
             else if digit == 2 { "2" }
             else if digit == 3 { "3" }
             else if digit == 4 { "4" }
             else if digit == 5 { "5" }
             else if digit == 6 { "6" }
             else if digit == 7 { "7" }
             else if digit == 8 { "8" }
             else { "9" }
    result = char + result
    temp = temp / 10
  }

  if negative {
    return "-" + result
  }
  return result
}
