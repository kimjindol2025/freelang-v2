use "std/net"

// ──────────────────────────────────────────────────────────────────────────
// 1. 소켓 관리
// ──────────────────────────────────────────────────────────────────────────

type ServerSocket = {
  fd: i32,              // 파일 디스크립터
  host: string,
  port: i32,
  backlog: i32,         // 대기 큐 크기
  isListening: bool
}

type ClientConnection = {
  fd: i32,              // 클라이언트 파일 디스크립터
  remoteHost: string,
  remotePort: i32,
  isConnected: bool,
  readBuffer: string,
  writeBuffer: string
}

func createServerSocket(host: string, port: i32, backlog: i32) -> ServerSocket {
  return {
    fd: 0,
    host: host,
    port: port,
    backlog: backlog,
    isListening: false
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 2. 소켓 바인드 및 수신 대기
// ──────────────────────────────────────────────────────────────────────────

func bindSocket(socket: ServerSocket) -> bool {
  // std/net을 이용한 소켓 바인드
  // net.socket(AF_INET, SOCK_STREAM) → 파일 디스크립터
  // net.setsockopt(fd, SO_REUSEADDR, 1)
  // net.bind(fd, host, port)
  // net.listen(fd, backlog)

  println("📍 바인드 중: " + socket.host + ":" + i32ToString(socket.port))

  // 실제 구현 (std/net 지원 필요)
  socket.isListening = true
  socket.fd = 1  // 실제로는 net.socket()의 반환값

  println("✅ 바인드 완료 (fd=" + i32ToString(socket.fd) + ")")
  return true
}

func acceptConnection(socket: ServerSocket) -> ClientConnection {
  // net.accept(socket.fd) → (clientFd, remoteHost, remotePort)
  // 클라이언트 연결 수락 및 새로운 파일 디스크립터 반환

  return {
    fd: 2,                    // 실제로는 net.accept()의 반환값
    remoteHost: "127.0.0.1",
    remotePort: 54321,
    isConnected: true,
    readBuffer: "",
    writeBuffer: ""
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 3. 데이터 읽기 및 쓰기
// ──────────────────────────────────────────────────────────────────────────

