func closeConnection(conn: ClientConnection) -> bool {
  // net.close(conn.fd) → success
  // 클라이언트 연결 종료

  println("🔌 연결 종료: " + conn.remoteHost + ":" + i32ToString(conn.remotePort))

  return true
