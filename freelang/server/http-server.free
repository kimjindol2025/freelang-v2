func getStyleCss() -> string {
  return `/* 스타일 시트 */`
}

func getFreelangBridgeJs() -> string {
  return `// FreeLang 브리지 객체
window.freelang = {
    apiBase: 'http://127.0.0.1:3000',

    async request(method, path, data) {
        const startTime = performance.now();
        try {
            const options = {
                method: method,
                headers: {
                    'Content-Type': 'application/json'
                }
            };

            if (data && method !== 'GET') {
                options.body = JSON.stringify(data);
            }

            const response = await fetch(this.apiBase + path, options);
            const result = await response.json();

            const duration = (performance.now() - startTime).toFixed(2);
            window.debug?.logRequest(method, path, duration);

            return result;
        } catch (error) {
            console.error('Freelang request error:', error);
            return { status: 'error', message: error.message };
        }
    },

    counter: {
        async get() {
            return window.freelang.request('GET', '/api/counter');
        },
        async increment() {
            return window.freelang.request('POST', '/api/counter/increment');
        },
        async decrement() {
            return window.freelang.request('POST', '/api/counter/decrement');
        },
        async reset() {
            return window.freelang.request('POST', '/api/counter/reset');
        }
    }
};

// 디버그 객체
window.debug = {
    requestCount: 0,
    logRequest(method, path, duration) {
        this.requestCount++;
        console.log(\`[\${method}] \${path} - \${duration}ms (Total: \${this.requestCount})\`);
    }
};`
}

func getMainJs() -> string {
  return `// 이벤트 핸들러 + 상태 관리
let requestCount = 0;

async function updateCounter() {
    const result = await window.freelang.counter.get();
    if (result.status === 'success') {
        document.getElementById('counter').innerText = result.data.count;
    }
}

async function handleIncrement() {
    showLoading();
    const result = await window.freelang.counter.increment();
    if (result.status === 'success') {
        updateCounter();
        updateStats('증가됨');
    }
    hideLoading();
}

async function handleDecrement() {
    showLoading();
    const result = await window.freelang.counter.decrement();
    if (result.status === 'success') {
        updateCounter();
        updateStats('감소됨');
    }
    hideLoading();
}

async function handleReset() {
    showLoading();
    const result = await window.freelang.counter.reset();
    if (result.status === 'success') {
        updateCounter();
        updateStats('초기화됨');
    }
    hideLoading();
}

function updateStats(action) {
    requestCount++;
    document.getElementById('requests').innerText = requestCount;
    document.getElementById('status').innerText = action;
    document.getElementById('response-time').innerText = 'OK';
}

function showLoading() {
    document.getElementById('loading').classList.add('active');
}

function hideLoading() {
    document.getElementById('loading').classList.remove('active');
}

// 이벤트 리스너 등록
document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('btn-increment').addEventListener('click', handleIncrement);
    document.getElementById('btn-decrement').addEventListener('click', handleDecrement);
    document.getElementById('btn-reset').addEventListener('click', handleReset);

    // 초기 로드
    updateCounter();
    document.getElementById('status').innerText = '준비됨';
});`
}

// ──────────────────────────────────────────────────────────────────────────
// 요청 파싱
// ──────────────────────────────────────────────────────────────────────────

func parseHttpRequest(rawRequest: string) -> HttpRequest {
  let lines = rawRequest.split("\n")
  let firstLine = lines[0].split(" ")

  let method = firstLine[0]
  let pathWithQuery = firstLine[1]
  let pathParts = pathWithQuery.split("?")
  let path = pathParts[0]
  let query = parseQueryString(pathParts.length > 1 ? pathParts[1] : "")

  let headers: map<string, string> = {}
  let bodyStart = 0

  for i in 1..lines.length {
    if lines[i] == "" {
      bodyStart = i + 1
      break
    }

    let headerParts = lines[i].split(": ")
    if headerParts.length == 2 {
      headers[headerParts[0].toLowerCase()] = headerParts[1]
    }
  }

  let body = bodyStart < lines.length ? lines[bodyStart..].join("\n") : ""

  return {
    method: method,
    path: path,
    query: query,
    headers: headers,
    body: body
  }
}

func parseQueryString(query: string) -> map<string, string> {
  let params: map<string, string> = {}

  if query == "" {
    return params
  }

  let parts = query.split("&")
  for part in parts {
    let pair = part.split("=")
    if pair.length == 2 {
      params[pair[0]] = pair[1]
    }
  }

  return params
}

// ──────────────────────────────────────────────────────────────────────────
// 응답 생성
// ──────────────────────────────────────────────────────────────────────────

func buildHttpResponse(response: HttpResponse) -> string {
  let status = getStatusText(response.status)
  let result = "HTTP/1.1 \(response.status) \(status)\r\n"

  result += "Server: FreeLang/1.0\r\n"
  result += "Connection: close\r\n"
  result += "Content-Length: \(response.body.length)\r\n"

  for key, value in response.headers {
    result += "\(key): \(value)\r\n"
  }

  result += "\r\n"
  result += response.body

  return result
}

func getStatusText(status: number) -> string {
  match status {
    200 => "OK"
    201 => "Created"
    400 => "Bad Request"
    404 => "Not Found"
    500 => "Internal Server Error"
    default => "Unknown"
  }
}

// ──────────────────────────────────────────────────────────────────────────
// CORS 헤더
// ──────────────────────────────────────────────────────────────────────────

func getCorsHeaders() -> map<string, string> {
  return {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
    "Access-Control-Allow-Headers": "Content-Type"
  }
}

// ──────────────────────────────────────────────────────────────────────────
