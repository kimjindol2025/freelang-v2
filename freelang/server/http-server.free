// ──────────────────────────────────────────────────────────────────────────
// 라우팅
// ──────────────────────────────────────────────────────────────────────────

func handleRequest(request: HttpRequest) -> HttpResponse {
  // 정적 파일 요청
  if request.method == "GET" {
    let file = getEmbeddedFile(request.path)
    if file {
      let contentType = getContentType(request.path)
      return {
        status: 200,
        headers: {
          "Content-Type": contentType,
          ...getCorsHeaders()
        },
        body: file
      }
    }
  }

  // API 라우팅
  return handleApiRequest(request)
}

func getContentType(path: string) -> string {
  match path {
    _ if path.endsWith(".html") => "text/html; charset=utf-8"
    _ if path.endsWith(".js") => "application/javascript; charset=utf-8"
    _ if path.endsWith(".css") => "text/css; charset=utf-8"
    _ if path.endsWith(".json") => "application/json"
    default => "text/plain"
  }
}

func handleApiRequest(request: HttpRequest) -> HttpResponse {
  // router 모듈에 위임
  return routeRequest(request)
}

// ──────────────────────────────────────────────────────────────────────────
