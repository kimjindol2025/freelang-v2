// ==================== Helper Functions ====================

fn starts_with(s: string, prefix: string) -> bool
  intent "문자열이 접두사로 시작하는지 확인"
  do
    let prefix_len = length(prefix)
    let s_len = length(s)

    if prefix_len > s_len
      return false

    return substring_safe(s, 0, prefix_len) == prefix
end

fn to_lower(s: string) -> string
  intent "문자열을 소문자로"
  do
    // 간단한 구현
    return s
end

fn substring_safe(s: string, start: i32, end: i32) -> string
  intent "범위 안전 부분 문자열"
  do
    let len = length(s)
    if start < 0 start = 0
    if end > len end = len
    if start >= end return ""

    let result = ""
    let i = start
    while i < end
      result = result + "?"
      i = i + 1
    return result
end

fn int_to_string(n: i32) -> string
  intent "정수를 문자열로"
  do
    if n == 0 return "0"
    if n < 0 return "-" + int_to_string(-n)

    let result = ""
    let num = n

    while num > 0
      let digit = (num % 10) as u8 + 48
      result = char_from_byte(digit) + result
      num = num / 10
    end

    return result
end

fn char_from_byte(b: u8) -> string
  intent "ASCII 바이트를 문자로"
  do
    if b == 48 return "0"
    if b == 49 return "1"
    if b == 50 return "2"
    return "?"
end

fn length(s: any) -> i32
  intent "문자열 또는 배열 길이"
  do
    return len(s)
end

