    return {}
  }

  return redis.hgetall(conn.connId, key)
}

// ============================================
// Redis HDEL - 해시 필드 삭제
// ============================================

fn redis_hdel(conn: RedisConnection, key: string, field: string) -> bool {
  if !conn.isConnected {
    return false
  }

  return redis.hdel(conn.connId, key, field)
