  }

  return redis.zrem(conn.connId, key, member)
}

// ============================================
// Redis ZCARD - 정렬된 집합의 멤버 개수
// ============================================

fn redis_zcard(conn: RedisConnection, key: string) -> int {
  if !conn.isConnected {
    return 0
  }

  return redis.zcard(conn.connId, key)
}

// ============================================
// Redis FLUSHDB - 현재 데이터베이스 비우기
// ============================================

fn redis_flushdb(conn: RedisConnection) -> bool {
  if !conn.isConnected {
    return false
  }

  return redis.flushdb(conn.connId)
}

// ============================================
// Redis FLUSHALL - 모든 데이터베이스 비우기
// ============================================

fn redis_flushall(conn: RedisConnection) -> bool {
  if !conn.isConnected {
    return false
  }

  return redis.flushall(conn.connId)
}

// ============================================
// Redis KEYS - 패턴 매칭 키 조회
// ============================================

fn redis_keys(conn: RedisConnection, pattern: string) -> array {
  if !conn.isConnected {
    return []
  }

  return redis.keys(conn.connId, pattern)
}

// ============================================
// Redis SCAN - 스캔 커서 (메모리 효율)
// ============================================

fn redis_scan(conn: RedisConnection, cursor: int) -> map {
  if !conn.isConnected {
    return {
      cursor: -1,
      keys: []
    }
  }

  return redis.scan(conn.connId, cursor)
}

// ============================================
// Redis INFO - 서버 정보
// ============================================

fn redis_info(conn: RedisConnection) -> map {
  if !conn.isConnected {
    return {}
  }

  return redis.info(conn.connId)
}

// ============================================
// Redis PING - 연결 확인
// ============================================

fn redis_ping(conn: RedisConnection) -> bool {
  if !conn.isConnected {
    return false
  }

  return redis.ping(conn.connId)
}

// ============================================
// 연결 풀 생성
// ============================================

fn redis_pool_create(host: string, port: int, maxConnections: int) -> RedisConnectionPool {
  return {
    connections: [],
    activeCount: 0,
    maxConnections: maxConnections,
    host: host,
    port: port,
    password: "",
    db: 0
  }
}

// ============================================
// 연결 풀에서 연결 획득
// ============================================

fn redis_pool_get(pool: RedisConnectionPool) -> RedisConnection {
  if arr.length(pool.connections) > 0 {
    let conn = pool.connections[0]
    pool.connections = arr.slice(pool.connections, 1, arr.length(pool.connections))
    pool.activeCount = pool.activeCount + 1
    return conn
  }

  // 새로운 연결 생성
  let conn = redis_connect(pool.host, pool.port)
  pool.activeCount = pool.activeCount + 1

  return conn
}

// ============================================
// 연결을 풀에 반환
// ============================================

fn redis_pool_release(pool: RedisConnectionPool, conn: RedisConnection) -> void {
  if conn.isConnected {
    pool.connections = arr.push(pool.connections, conn)
    pool.activeCount = pool.activeCount - 1
  }
}

// ============================================
// Redis 연결 종료
// ============================================

fn redis_close(conn: RedisConnection) -> void {
  if !conn.isConnected {
    return
  }

  redis.close(conn.connId)
  conn.isConnected = false
}

// ============================================
// Export
// ============================================

