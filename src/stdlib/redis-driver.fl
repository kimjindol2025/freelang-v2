  redis_getdel,
  redis_exists,
  redis_del,
  redis_del_multiple,
  redis_expire,
  redis_ttl,
  redis_persist,
  redis_incr,
  redis_incrby,
  redis_decr,
  redis_decrby,

  redis_hset,
  redis_hget,
  redis_hgetall,
  redis_hdel,
  redis_hexists,
  redis_hlen,

  redis_lpush,
  redis_rpush,
  redis_lpop,
  redis_rpop,
  redis_llen,
  redis_lrange,

  redis_sadd,
  redis_srem,
  redis_smembers,
  redis_sismember,
  redis_scard,

  redis_zadd,
  redis_zrange,
  redis_zrem,
  redis_zcard,

  redis_flushdb,
  redis_flushall,
  redis_keys,
  redis_scan,
  redis_info,
  redis_ping,

  redis_pool_create,
  redis_pool_get,
  redis_pool_release,

  redis_close
}
