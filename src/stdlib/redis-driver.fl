/**
 * FreeLang Redis Driver
 *
 * Redis 캐시 및 데이터 저장소 연결
 * - redis_connect: Redis 서버에 연결
 * - redis_get/set: 키-값 저장소 기본 API
 * - redis_del: 키 삭제
 * - redis_expire: TTL 설정
 * - redis_hset/hget: 해시 자료구조
 * - redis_lpush/lpop: 리스트 자료구조
 * - redis_sadd/smembers: 집합 자료구조
 * - redis_zadd/zrange: 정렬된 집합
 * - redis_close: 연결 종료
 *
 * Phase F 구현 (Redis 드라이버)
 */

// ============================================
// Redis 연결 구조체
// ============================================

struct RedisConnection {
  host: string,
  port: int,
  password: string,
  db: int,              // 데이터베이스 번호 (0-15)
  connId: int,          // Native connection ID
  isConnected: bool,
  lastError: string,
  selectedDb: int
}

// ============================================
// Redis 연결 풀
// ============================================

struct RedisConnectionPool {
  connections: array,   // 사용 가능한 연결 목록
  activeCount: int,
  maxConnections: int,
  host: string,
  port: int,
  password: string,
  db: int
}

// ============================================
// Redis 명령 결과
// ============================================

struct RedisResult {
  value: any,
  success: bool,
  error: string,
  type: string          // "string", "int", "array", "null"
}

// ============================================
// Redis 연결 생성
// ============================================

fn redis_connect(host: string, port: int) -> RedisConnection {
  // Native redis.connect 호출
  let connId = redis.connect(host, port, "")

  if connId < 0 {
    return {
      host: host,
      port: port,
      password: "",
      db: 0,
      connId: -1,
      isConnected: false,
      lastError: "Failed to connect to Redis server",
      selectedDb: 0
    }
  }

  return {
    host: host,
    port: port,
    password: "",
    db: 0,
    connId: connId,
    isConnected: true,
    lastError: "",
    selectedDb: 0
  }
}

// ============================================
// Redis 인증 연결
// ============================================

fn redis_connect_auth(host: string, port: int, password: string) -> RedisConnection {
  // Native redis.connect with password
  let connId = redis.connect(host, port, password)

  if connId < 0 {
    return {
      host: host,
      port: port,
      password: password,
      db: 0,
      connId: -1,
      isConnected: false,
      lastError: "Failed to connect to Redis server (auth failed)",
      selectedDb: 0
    }
  }

  return {
    host: host,
    port: port,
    password: password,
    db: 0,
    connId: connId,
    isConnected: true,
    lastError: "",
    selectedDb: 0
  }
}

// ============================================
// Redis 데이터베이스 선택
// ============================================

fn redis_select_db(conn: RedisConnection, db: int) -> bool {
  if !conn.isConnected || db < 0 || db > 15 {
    return false
  }

  let result = redis.select(conn.connId, db)
  if result {
    conn.selectedDb = db
    conn.db = db
  }

  return result
}

// ============================================
// Redis GET - 문자열 값 조회
// ============================================

fn redis_get(conn: RedisConnection, key: string) -> string {
  if !conn.isConnected {
    return ""
  }

  let value = redis.get(conn.connId, key)
  return value != null ? value : ""
}

// ============================================
// Redis SET - 문자열 값 저장
// ============================================

fn redis_set(conn: RedisConnection, key: string, value: string) -> bool {
  if !conn.isConnected {
    return false
  }

  return redis.set(conn.connId, key, value)
}

// ============================================
// Redis SET with TTL - TTL을 포함한 저장
// ============================================

fn redis_set_ex(conn: RedisConnection, key: string, value: string, seconds: int) -> bool {
  if !conn.isConnected || seconds <= 0 {
    return false
  }

  return redis.setex(conn.connId, key, value, seconds)
}

// ============================================
// Redis GET and DELETE - 원자적 연산
// ============================================

fn redis_getdel(conn: RedisConnection, key: string) -> string {
  if !conn.isConnected {
    return ""
  }

  let value = redis.get(conn.connId, key)
  redis.del(conn.connId, key)

  return value != null ? value : ""
}

// ============================================
// Redis EXISTS - 키 존재 확인
// ============================================

fn redis_exists(conn: RedisConnection, key: string) -> bool {
  if !conn.isConnected {
    return false
  }

  return redis.exists(conn.connId, key)
}

// ============================================
// Redis DEL - 키 삭제
// ============================================

fn redis_del(conn: RedisConnection, key: string) -> bool {
  if !conn.isConnected {
    return false
  }

  return redis.del(conn.connId, key)
}

// ============================================
// Redis DEL MULTIPLE - 여러 키 삭제
// ============================================

fn redis_del_multiple(conn: RedisConnection, keys: array) -> int {
  if !conn.isConnected || arr.length(keys) == 0 {
    return 0
  }

  return redis.del_multiple(conn.connId, keys)
}

// ============================================
// Redis EXPIRE - TTL 설정
// ============================================

fn redis_expire(conn: RedisConnection, key: string, seconds: int) -> bool {
  if !conn.isConnected || seconds <= 0 {
    return false
  }

  return redis.expire(conn.connId, key, seconds)
}

// ============================================
// Redis TTL - 남은 시간 조회
// ============================================

fn redis_ttl(conn: RedisConnection, key: string) -> int {
  if !conn.isConnected {
    return -2  // 키 없음
  }

  return redis.ttl(conn.connId, key)
}

// ============================================
// Redis PERSIST - TTL 제거
// ============================================

fn redis_persist(conn: RedisConnection, key: string) -> bool {
  if !conn.isConnected {
    return false
  }

  return redis.persist(conn.connId, key)
}

// ============================================
// Redis INCR - 정수 증가
// ============================================

fn redis_incr(conn: RedisConnection, key: string) -> int {
  if !conn.isConnected {
    return -1
  }

  return redis.incr(conn.connId, key)
}

// ============================================
// Redis INCRBY - 지정값만큼 증가
// ============================================

fn redis_incrby(conn: RedisConnection, key: string, value: int) -> int {
  if !conn.isConnected || value < 0 {
    return -1
  }

  return redis.incrby(conn.connId, key, value)
}

// ============================================
// Redis DECR - 정수 감소
// ============================================

fn redis_decr(conn: RedisConnection, key: string) -> int {
  if !conn.isConnected {
    return -1
  }

  return redis.decr(conn.connId, key)
}

// ============================================
// Redis DECRBY - 지정값만큼 감소
// ============================================

fn redis_decrby(conn: RedisConnection, key: string, value: int) -> int {
  if !conn.isConnected || value < 0 {
    return -1
  }

  return redis.decrby(conn.connId, key, value)
}

