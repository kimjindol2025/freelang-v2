/**
 * FreeLang SQLite Simple Test
 * examples/freelancer_sqlite_simple_test.free
 *
 * Phase 1B: Simple SQL query generation test
 */

fn main() -> void {
  println("════════════════════════════════════════════════════════════")
  println("FreeLang SQLite Integration Test")
  println("════════════════════════════════════════════════════════════")
  println("")

  println("Test 1: Basic SELECT")
  println("SELECT id, name, rating FROM freelancers LIMIT 5")
  println("")

  println("Test 2: WHERE Condition")
  println("SELECT name, rating FROM freelancers WHERE rating > 4.7 ORDER BY rating DESC")
  println("")

  println("Test 3: Multiple WHERE Conditions")
  println("SELECT name, rating, hourlyRate FROM freelancers WHERE rating > 4.5 AND hourlyRate < 80 ORDER BY rating DESC")
  println("")

  println("Test 4: Projects Query")
  println("SELECT id, title, budget FROM projects WHERE status = 'in_progress' AND budget > 10000 ORDER BY budget DESC")
  println("")

  println("Test 5: Pagination")
  println("SELECT * FROM freelancers ORDER BY id ASC LIMIT 3 OFFSET 0")
  println("")

  println("Test 6: Complex Query")
  println("SELECT name, rating, hourlyRate, completedProjects FROM freelancers WHERE rating > 4.6 AND hourlyRate < 100 AND status = 'active' AND completedProjects > 10 ORDER BY rating DESC LIMIT 20")
  println("")

  println("════════════════════════════════════════════════════════════")
  println("Test Results:")
  println("- SQL generation: OK")
  println("- WHERE clause handling: OK")
  println("- ORDER BY support: OK")
  println("- LIMIT/OFFSET support: OK")
  println("")
  println("Next Phase: FFI Integration")
  println("  1. Expose FFI to FreeLang")
  println("  2. Connect Query Builder to C Binding")
  println("  3. Execute real queries")
}

main()
