// 포스트 CRUD, 읽기 시간 계산, 마크다운 처리

pub struct Post {
  id: i32,
  title: string,
  description: string,
  content: string,
  author: string,
  category: string,
  tags: string,
  slug: string,
  featured: bool,
  status: string,
  isDraft: bool,
  createdAt: i64,
  updatedAt: i64,
  viewCount: i32,
  likes: i32,
  readingTime: i32,
  readingTimeDisplay: string
}

pub struct BlogDb {
  posts: map<i32, Post>,
  nextId: i32,
  dataPath: string
}

// 1. 데이터베이스 초기화
pub fn blog_db_new(dataPath: string) -> BlogDb {
  intent "새 블로그 데이터베이스 생성"
  do
    let db = BlogDb {
      posts: {},
      nextId: 1,
      dataPath: dataPath
    }

    blog_db_load(&db)
    return db
  end
}

// 2. 파일에서 데이터 로드
