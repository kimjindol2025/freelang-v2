  println("  총 프리랜서: 5명")
  println("  총 프로젝트: 5개")
  println("  평균 평점: 4.8/5.0")
  println("  평균 시급: $63/hr")
  println("")

  // 쿼리 예제
  println("🎯 쿼리 예제")
