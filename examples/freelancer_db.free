  println("  101. 이커머스 플랫폼 개발 ($5000, 완료)")
  println("  102. 모바일 앱 개발 ($8000, 진행중)")
  println("  103. 마이크로서비스 아키텍처 ($12000, 진행중)")
  println("  104. UI/UX 디자인 ($3000, 완료)")
  println("  105. 고성능 백엔드 시스템 ($15000, 대기중)")
  println("")

  // 기술 스택
  println("🔧 인기 기술 스택")
  println("  Python: 수요도 95/100, 평균 시급 $45")
  println("  JavaScript: 수요도 90/100, 평균 시급 $40")
  println("  React: 수요도 85/100, 평균 시급 $50")
  println("  Node.js: 수요도 80/100, 평균 시급 $55")
  println("  Java: 수요도 75/100, 평균 시급 $60")
  println("  Go: 수요도 70/100, 평균 시급 $75")
  println("  Rust: 수요도 60/100, 평균 시급 $85")
  println("")

  // 통계
