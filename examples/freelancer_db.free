  // 프리랜서 정보
  println("👤 프리랜서 목록")
  println("  1. 김준호 - Python, JavaScript, React (평점: 4.8, $50/hr)")
  println("  2. 이수진 - Node.js, MongoDB, AWS (평점: 4.9, $60/hr)")
  println("  3. 박민철 - Java, Spring, Kubernetes (평점: 4.7, $70/hr)")
