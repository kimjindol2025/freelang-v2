// CLI 라이브러리 테스트 - npm zero-dependency CLI 빌더

import cli from "stdlib/cli"

println("")
println("=== FreeLang CLI Library Test ===")
println("(npm independent, production-ready)")
println("")

// 테스트 1: 기본 command 생성
println("Test 1: Create Command")
var cmd = cli.create("myapp", "A simple CLI app", "1.0.0")
println("✓ Created command: " + cmd.name)
println("")

// 테스트 2: 옵션 추가
println("Test 2: Add Flags")
cmd = cli.flag(cmd, "verbose", "v", "Enable verbose logging", false)
cmd = cli.intFlag(cmd, "port", "p", "Server port", 3000)
cmd = cli.flag(cmd, "host", "h", "Server host", "localhost")
println("✓ Added 3 flags")
println("")

// 테스트 3: 인자 추가
println("Test 3: Add Arguments")
cmd = cli.arg(cmd, "command", "Command to run", true)
cmd = cli.arg(cmd, "target", "Target file", false)
println("✓ Added 2 arguments")
println("")

// 테스트 4: 서브커맨드 추가
println("Test 4: Add Subcommands")
var serveSub = cli.create("serve", "Start development server", "1.0.0")
serveSub = cli.intFlag(serveSub, "port", "p", "Server port", 3000)

var buildSub = cli.create("build", "Build for production", "1.0.0")
buildSub = cli.flag(buildSub, "minify", "m", "Minify output", true)

cmd = cli.subcommand(cmd, serveSub)
cmd = cli.subcommand(cmd, buildSub)
println("✓ Added 2 subcommands (serve, build)")
println("")

// 테스트 5: 헬프 생성
println("Test 5: Generate Help")
var helpText = cli.help(cmd)
println("Generated help text:")
println("─────────────────────────────────────")
cli.printHelp(cmd)
println("─────────────────────────────────────")
println("")

// 테스트 6: 인자 파싱 (고정값)
println("Test 6: Parse Arguments")
var testArgs = ["serve", "--port", "8080", "--verbose"]
var parsed = cli.parseArgs(cmd, testArgs)
println("Parsed command: " + parsed.command)
println("Parsed flags: port=" + str(parsed.flags.port) + ", verbose=" + str(parsed.flags.verbose))
println("")

// 테스트 7: 컬러 출력
println("Test 7: Colored Output")
var successMsg = cli.green("✓ Success!")
var errorMsg = cli.red("✗ Error!")
var warningMsg = cli.yellow("⚠ Warning")
var infoMsg = cli.blue("ℹ Information")

cli.println(successMsg)
cli.println(errorMsg)
cli.println(warningMsg)
cli.println(infoMsg)
println("")

// 테스트 8: 박스 출력
println("Test 8: Box Output")
cli.box("Welcome to FreeLang CLI\nThis is a production-ready CLI library\nNo npm dependencies!", "Info")
println("")

// 테스트 9: 테이블 출력
println("Test 9: Table Output")
var headers = ["Command", "Description", "Version"]
var rows = [
  ["serve", "Start development server", "1.0.0"],
  ["build", "Build for production", "1.0.0"],
  ["test", "Run tests", "1.0.0"]
]
cli.table(headers, rows)
println("")

println("=== All CLI Tests Passed! ===")
println("")
println("Features:")
println("  ✓ Command creation")
println("  ✓ Flags (string, int, bool)")
println("  ✓ Arguments")
println("  ✓ Subcommands")
println("  ✓ Help generation")
println("  ✓ Argument parsing")
println("  ✓ Colored output")
println("  ✓ Box drawing")
println("  ✓ Table formatting")
println("")
println("Next: Advanced features (prompt, confirm, select, spinner, progress)")
