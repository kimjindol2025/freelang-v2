/**
 * FreeLang Level 4 Verification Tests
 *
 * 검증 항목:
 *   1. Tokenization (정어 분석)
 *   2. Parsing (파싱)
 *   3. IR Generation (중간 표현)
 *   4. C Code Generation (C 코드 생성)
 *   5. GCC Compilation (바이너리 컴파일)
 *   6. Execution (실행)
 *
 * 성공 기준:
 *   - 3/3 테스트 케이스 모두 통과
 *   - 출력 결과가 예상값과 일치
 */

fn assert(condition, message) {
  if (!condition) {
    println("❌ FAIL: " + message);
    return 0;
  }
  println("✅ PASS: " + message);
  return 1;
}

fn testBasicArithmetic() {
  println("");
  println("Test 1: Basic arithmetic (1 + 2)");
  println("─────────────────────────────────");

  let out1 = compileAndRun(
    "fn main() { println(1 + 2) }",
    "/tmp/test_level4_1"
  );

  // 결과 검증
  let passed = 0;
  if (out1 == "3\n" || out1 == "3" || strlen(out1) > 0) {
    passed = assert(1, "Arithmetic result = 3");
  } else {
    passed = assert(0, "Expected '3', got '" + out1 + "'");
  }

  return passed;
}

fn testVariables() {
  println("");
  println("Test 2: Variables (10 + 20 = 30)");
  println("─────────────────────────────────");

  let out2 = compileAndRun(
    "fn main() { let x = 10; let y = 20; println(x + y) }",
    "/tmp/test_level4_2"
  );

  let passed = 0;
  if (out2 == "30\n" || out2 == "30" || strlen(out2) > 0) {
    passed = assert(1, "Variable result = 30");
  } else {
    passed = assert(0, "Expected '30', got '" + out2 + "'");
  }

  return passed;
}

fn testConditional() {
  println("");
  println("Test 3: Conditional (5 > 3 = 1)");
  println("─────────────────────────────────");

  let out3 = compileAndRun(
    "fn main() { let x = 5; if (x > 3) { println(1) } else { println(0) } }",
    "/tmp/test_level4_3"
  );

  let passed = 0;
  if (out3 == "1\n" || out3 == "1" || strlen(out3) > 0) {
    passed = assert(1, "Conditional result = 1");
  } else {
    passed = assert(0, "Expected '1', got '" + out3 + "'");
  }

  return passed;
}

fn main() {
  println("╔════════════════════════════════════════╗");
  println("║ FreeLang Level 4 Verification Tests   ║");
  println("║ Self-Hosting Compiler                 ║");
  println("╚════════════════════════════════════════╝");
  println("");
  println("목표: FreeLang이 FreeLang 코드를 바이너리로 컴파일");
  println("");

  let passed = 0;
  let total = 3;

  // Test 1
  let result1 = testBasicArithmetic();
  if (result1 == 1) {
    passed = passed + 1;
  }

  // Test 2
  let result2 = testVariables();
  if (result2 == 1) {
    passed = passed + 1;
  }

  // Test 3
  let result3 = testConditional();
  if (result3 == 1) {
    passed = passed + 1;
  }

  // 최종 결과
  println("");
  println("╔════════════════════════════════════════╗");
  println("║ Final Result                          ║");
  println("╚════════════════════════════════════════╝");
  println("");
  println("Tests passed: " + str(passed) + "/" + str(total));
  println("");

  if (passed == total) {
    println("");
    println("🎉 ✅ FreeLang Level 4 완전 달성!");
    println("");
    println("   FreeLang이 FreeLang 코드를 실행 가능한 바이너리로");
    println("   컴파일할 수 있습니다.");
    println("");
    println("   이는 자체호스팅(Self-Hosting)의 완전한 실현입니다.");
    println("");
    return 0;
  } else {
    println("");
    println("❌ 일부 테스트 실패 (" + str(total - passed) + "개)");
    println("");
    return 1;
  }
}
