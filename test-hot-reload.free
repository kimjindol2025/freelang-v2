// Native-Hot-Reload 데모 - v3 교체 버전
// @hot 어노테이션: 저장 시 이 함수만 재컴파일 + 교체

@hot
fn handle_request() -> string {
    return "FreeLang v2: 핫 리로드 v3 - 완전히 새로운 로직!"
}

fn static_helper() -> string {
    return "static_helper: 변경 안 됨"
}

let msg = handle_request()
println(msg)
let helper = static_helper()
println(helper)
println("@hot 함수만 실시간 교체됩니다. static_helper는 교체 안 됩니다.")
