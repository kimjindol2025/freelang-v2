// Safe test that avoids array access issues

println("=== Self-Lexer Safe Test ===")

// Test 1: String operations
let source = "hello world"
let len = string_length(source)
let ch = charAt(source, 0)
println("✅ String operations work")

// Test 2: Array push
let arr = []
push(arr, 1)
push(arr, 2)
push(arr, 3)
println("✅ Array push works")

// Test 3: Array length
let arr_len = length(arr)
println("✅ Array length works")

// Test 4: Object literals
let token = { kind: "KEYWORD", value: "fn" }
println("✅ Object literals work")

// Test 5: String in object
let token2 = { kind: "NUMBER", value: "42" }
println("✅ Token objects work")

